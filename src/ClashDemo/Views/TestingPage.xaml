<Page x:Class="ClashDemo.Views.TestingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClashDemo.Views"
      xmlns:athelpers="clr-namespace:Clash.UI.Suppot.UI.Helpers;assembly=Clash.UI.Suppot"
      mc:Ignorable="d" 
      Name="测试"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TestingPage">

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Canvas  Background="{DynamicResource commonBarBrush}">
            <Canvas.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="2" Opacity="0.6"/>
            </Canvas.Effect>
            <TextBlock Canvas.Top="18" Canvas.Left="20" FontSize="20" Text="测 试" FontWeight="Bold" VerticalAlignment="Center"/>
        </Canvas>


        <Grid Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}">

            <DockPanel LastChildFill="True" >
                <StackPanel DockPanel.Dock="Right" Width="150" Background="#EEEEEE">
                    <Button
                        Height="50"
                        Content="灰度化" 
                        Click="btnGray_Click" 
                        Margin="10"
                        athelpers:AttachPropertyHelper.AutoCornerRadius="8"/>
                    <Button
                        Height="50"
                        Content="像素处理" 
                            Click="btnPixel_Click" 
                            Margin="10"
                            athelpers:AttachPropertyHelper.AutoCornerRadius="8"/>
                </StackPanel>
                <Image Margin="10"
                x:Name="img" Source="/Icons/128x128@2x.png"/>
            </DockPanel>

        </Grid>
    </Grid>
</Page>
