<UserControl x:Class="ClashDemo.Views.SubPages.IPMessageBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClashDemo.Views.SubPages"
             xmlns:vm="clr-namespace:ClashDemo.ViewModels.SubPageViewModels"
             xmlns:components="clr-namespace:Clash.UI.Suppot.UI.Componentes;assembly=Clash.UI.Suppot"
             mc:Ignorable="d"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
             d:DataContext="{d:DesignInstance Type=vm:IPMessagBoardViewModel}"
             Height="225"
             d:DesignHeight="225" d:DesignWidth="330">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3.2*"/>
        </Grid.RowDefinitions>

        <!--头部-->
        <Border CornerRadius="10 10 0 0" Background="#ffffff" Margin="0 0 0 1">
            <Grid>
                <Label Style="{StaticResource headerLabel}" 
                       Width="120"
                       HorizontalAlignment="Left" 
                       Content="IP 信息" 
                       Tag="{StaticResource locationGeometry}"/>
                <Button Name="flashButton" 
                    Style="{StaticResource circlButton}"
                        Width="30"
                                      Foreground="#757575"
                        Content="{StaticResource flashBoardGeometry}"
                                      Margin="0 0 20 0"
                        Command="{Binding FlashBoardCommand}"
                                      HorizontalAlignment="Right">
                    <Button.ToolTip>
                        <ToolTip Content="刷新" Style="{StaticResource RectToolTip}"/>
                    </Button.ToolTip>
                </Button>
            </Grid>
        </Border>
        <!--内容-->
        <Border Grid.Row="1" CornerRadius="0 0 10 10" Background="#ffffff"  >
            <Grid>
                <StackPanel Margin="0 10 0 0" Opacity="0" Background="Transparent" Tag="{Binding BoardStatu}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BoardStatu}" Value="Flashed">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding BoardStatu}" Value="Flash">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard  Name="flashAnimation">
                                            <Storyboard  RepeatBehavior="Forever">
                                                <DoubleAnimationUsingKeyFrames 
                                                             Storyboard.TargetProperty="Opacity"
                                                             >
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1.5" Value="1"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:2" Value="0"/>
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="flashAnimation"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                            <!--<Style.Triggers>
                                <Trigger Property="Tag" Value="Flash">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard  Name="flashAnimation">
                                            <Storyboard  RepeatBehavior="Forever">
                                                <DoubleAnimationUsingKeyFrames 
                                                             Storyboard.TargetProperty="Opacity"
                                                             >
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:1.5" Value="1"/>
                                                    <LinearDoubleKeyFrame KeyTime="0:0:2" Value="0"/>
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="flashAnimation"/>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>-->
                        </Style>
                    </StackPanel.Style>
                    <Border Margin="15 10 100 5" CornerRadius="4" Height="25" Background="#e3e3e3"/>
                    <Border Margin="15 10 40 5" CornerRadius="4" Height="20" Background="#e3e3e3"/>
                    <Border Margin="15 10 70 5" CornerRadius="4" Height="20" Background="#e3e3e3"/>
                    <Border Margin="15 10 150 5" CornerRadius="4" Height="20" Background="#e3e3e3"/>
                </StackPanel>
                <TextBlock Text="Finish" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BoardStatu}" Value="Flashed">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding BoardStatu}" Value="Flash">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

        </Border>
    </Grid>
</UserControl>
