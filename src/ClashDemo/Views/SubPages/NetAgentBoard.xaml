<UserControl x:Class="ClashDemo.Views.SubPages.NetAgentBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClashDemo.Views.SubPages"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:ClashDemo.ViewModels.SubPageViewModels"
             d:DataContext="{d:DesignInstance Type=vm:NetAgentBoardViewModel}"
             Height="255"
             d:DesignHeight="250" d:DesignWidth="330">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        
        <!--头部-->
        <Border CornerRadius="10 10 0 0" Background="#ffffff" Margin="0 0 0 1">
            <Grid>
                <Label Style="{StaticResource headerLabel}" 
                       Width="120"
                       HorizontalAlignment="Left" 
                       Content="当前节点" 
                       Tag="{StaticResource netAgentGeometry}"/>
                <controls:OrderButton 
                                      Foreground="Black"
                                      Margin="0 0 110 0"
                                      HorizontalAlignment="Right"/>
                <Button Style="{StaticResource circlButton}"
                                      Foreground="Black"
                        Content="{StaticResource flashStatus}"
                                      Margin="0 0 150 0"
                                      HorizontalAlignment="Right">
                    <Button.ToolTip>
                        <ToolTip Content="延迟测试" Style="{StaticResource RectToolTip}"/>
                    </Button.ToolTip>
                </Button>
                <Button Style="{StaticResource jumpButtonStyle}"
                                         Height="30"
                                         Width="75"
                        Margin="0 0 20 0"
                        Command="{Binding TargetPageNavigationCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=Self},Path=Content}"
                                         Content="代 理"
                                         HorizontalAlignment="Right"
                                         Tag="{StaticResource rightArrow}"/>
            </Grid>
        </Border>
        <!--内容-->
        <Border Grid.Row="1" CornerRadius="0 0 10 10" Background="#ffffff" >
            <StackPanel>
                <Border Height="64" 
                        Margin="10 15 10 2" 
                        CornerRadius="4" 
                        BorderThickness="1"
                        Background="#f2f8ff"
                        BorderBrush="#d9eaff">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="香港06" 
                                   VerticalAlignment="Center" 
                                   Margin="8 0 0 0" 
                                   FontSize="18"
                                   Grid.ColumnSpan="2"/>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="8 0 0 0">
                            <TextBlock Text="Vless" Foreground="#99878e" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Margin="8 0 0 0">
                                <Label Style="{StaticResource radiuoLabel}"  
                                       Content="UDP"/>
                                <Label Style="{StaticResource radiuoLabel}"  
                                       Width="50"
                                       Content="XUDP"/>
                            </StackPanel>
                        </StackPanel>
                        <Label Grid.Column="2" Grid.RowSpan="2" Style="{StaticResource radiuoLabel}"
                               Background="#06943d" BorderBrush="#06943d"
                               HorizontalAlignment="Right"
                               Margin="0 0 10 0"
                               Content="30"
                               Foreground="#FFFFFF"/>
                    </Grid>
                </Border>
                <controls:HeaderComboBox  SelectedIndex="0"  VerticalAlignment="Center" Header="代理组" >
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                    <ComboBoxItem Content="魔法喵"/>
                </controls:HeaderComboBox>
                <controls:HeaderComboBox  SelectedIndex="0"  VerticalAlignment="Center" Header="节点" >
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                    <ComboBoxItem Content="自动选择"/>
                </controls:HeaderComboBox>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
