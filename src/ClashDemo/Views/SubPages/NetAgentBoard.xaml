<UserControl x:Class="ClashDemo.Views.SubPages.NetAgentBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClashDemo.Views.SubPages"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
             mc:Ignorable="d"
             Height="255"
             d:DesignHeight="250" d:DesignWidth="330">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        
        <!--头部-->
        <Border CornerRadius="10 10 0 0" Background="#ffffff" Margin="0 0 0 1">
            <Grid>
                <Label Style="{StaticResource headerLabel}" 
                       Width="120"
                       HorizontalAlignment="Left" 
                       Content="当前节点" 
                       Tag="{StaticResource netAgentGeometry}"/>
                <controls:OrderButton Style="{StaticResource orderButton}"
                                      Foreground="Black"
                                      Margin="0 0 110 0"
                                      HorizontalAlignment="Right"/>
                <Button Style="{StaticResource jumpButtonStyle}"
                                         Height="30"
                                         Width="75"
                        Margin="0 0 20 0"
                                         Content="代 理"
                                         HorizontalAlignment="Right"
                                         Tag="{StaticResource rightArrow}"/>
            </Grid>
        </Border>
        <!--内容-->
        <Border Grid.Row="1" CornerRadius="0 0 10 10" Background="#ffffff" />
    </Grid>
</UserControl>
