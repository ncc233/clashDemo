<UserControl x:Class="ClashDemo.Views.SubPages.NetTestBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClashDemo.Views.SubPages"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:ClashDemo.ViewModels.SubPageViewModels"
             xmlns:components="clr-namespace:Clash.UI.Suppot.UI.Componentes;assembly=Clash.UI.Suppot"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
             xmlns:fhelpers="clr-namespace:ClashDemo.Helpers"
             d:DataContext="{d:DesignInstance Type=vm:NetTestBoardViewModel}"
             Height="225"
             d:DesignHeight="225" d:DesignWidth="330">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3.2*"/>
        </Grid.RowDefinitions>

        <!--头部-->
        <Border CornerRadius="10 10 0 0" Background="#ffffff" Margin="0 0 0 1">
            <Grid>
                <Label Style="{StaticResource headerLabel}" 
                       Width="120"
                       HorizontalAlignment="Left" 
                       Content="网站测试" 
                       Tag="{StaticResource TestNetGeometry}"/>
                <Button 
                    Style="{StaticResource circlButton}"
                        Width="30"
                        Foreground="#757575"
                        Content="{StaticResource TestNetGeometry}"
                        Margin="0 0 65 0"
                    Command="{Binding TestNetsCommand}"
                        HorizontalAlignment="Right">
                    <Button.ToolTip>
                        <ToolTip Content="网站测试" Style="{StaticResource RectToolTip}"/>
                    </Button.ToolTip>
                </Button>
                <Button Name="flashButton" 
                        Style="{StaticResource circlButton}"
                        Width="30"
                        Foreground="#757575"
                        Content="{StaticResource addTestBoardGeometry}"
                        Margin="0 0 20 0"
                        Command="{Binding ShowAddDialogCommand}"
                        HorizontalAlignment="Right">
                    <Button.ToolTip>
                        <ToolTip Content="添加测试" Style="{StaticResource RectToolTip}"/>
                    </Button.ToolTip>
                </Button>
            </Grid>
        </Border>
        <!--内容-->
        <Border Grid.Row="1" CornerRadius="0 0 10 10" Background="#ffffff"  >
            <Border.Resources>
                <fhelpers:MenuBindingHelper x:Key="vmContext" Data="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Grid},Path=DataContext}"/>
            </Border.Resources>
            <ScrollViewer  Margin="0 10 0 0" HorizontalAlignment="Center" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding TestItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <components:NetTestBlock
                                IsCurrentTest="{Binding IsTesting}"
                                TestName="{Binding BlockName}"
                                DelayMessage="{Binding NetDelay}"
                                Margin="4">
                                <components:NetTestBlock.Resources>
                                    <fhelpers:MenuBindingHelper x:Key="itemContext" Data="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=components:NetTestBlock},Path=DataContext}"/>
                                </components:NetTestBlock.Resources>
                                <components:NetTestBlock.ContextMenu>
                                    <ContextMenu Background="{StaticResource commonContextMenuBackgroundBrush}">
                                        <ContextMenu.Resources>
                                            <Style TargetType="ContextMenu">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ContextMenu">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="0" >
                                                                <ItemsPresenter Margin="0 4" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ContextMenu.Resources>
                                        <MenuItem Header="Edit" CommandParameter="{Binding Source={StaticResource itemContext},Path=Data}" 
                                                  Command="{Binding Source={StaticResource vmContext},Path=Data.EditNetTestBoardCommand}"/>
                                        <MenuItem Header="Delete" CommandParameter="{Binding Source={StaticResource itemContext},Path=Data}" 
                                                  Command="{Binding Source={StaticResource vmContext},Path=Data.DeleteNetTestBoardCommand}"/>
                                    </ContextMenu>
                                </components:NetTestBlock.ContextMenu>
                            </components:NetTestBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
