<Page
    x:Class="ClashDemo.Views.SettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ClashDemo.Views"
    xmlns:athelpers="clr-namespace:Clash.UI.Suppot.UI.Helpers;assembly=Clash.UI.Suppot"
    xmlns:theme="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2"
    Name="设置"
    Title="SettingPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="10*" />
        </Grid.RowDefinitions>
        <Canvas Background="{DynamicResource commonBarBrush}">
            <Canvas.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="2" Opacity="0.6" />
            </Canvas.Effect>
            <TextBlock
                Canvas.Left="20"
                Canvas.Top="18"
                VerticalAlignment="Center"
                FontSize="20"
                Text="设 置"
                FontWeight="Bold" />
        </Canvas>


        <Grid Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}">
            <StackPanel Margin="80">

                <ComboBox Width="90" Height="40" Style="{DynamicResource commonComboBoxStyle}">
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="All" />
                </ComboBox>
                <TextBox
                    Width="90"
                    Height="40"
                    athelpers:AttachPropertyHelper.AutoCornerRadius="8"
                    Text="110" />
                <TextBlock
                    Width="90"
                    Height="40"
                    athelpers:AttachPropertyHelper.AutoCornerRadius="8"
                    Background="Red"
                    Text="110" />
                <Button
                    Width="90"
                    Height="40"
                    athelpers:AttachPropertyHelper.AutoCornerRadius="8"
                    Content="110" />

            </StackPanel>
        </Grid>
    </Grid>
</Page>
