<Page x:Class="ClashDemo.Views.SettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClashDemo.Views"
      mc:Ignorable="d" 
      Name="设置"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingPage"
    xmlns:theme="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2">

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Canvas  Background="{DynamicResource commonBarBrush}">
            <Canvas.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="2" Opacity="0.6"/>
            </Canvas.Effect>
            <TextBlock Canvas.Top="18" Canvas.Left="20" FontSize="20" Text="设 置" FontWeight="Bold" VerticalAlignment="Center"/>
        </Canvas>


        <Grid Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}">
            <ComboBox Style="{DynamicResource commonComboBoxStyle}" Height="40" Width="90">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="All"/>
            </ComboBox>

        </Grid>
    </Grid>
</Page>
