<Page x:Class="ClashDemo.Views.HomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClashDemo.Views"
      xmlns:subview="clr-namespace:ClashDemo.Views.SubPages"
      xmlns:vm="clr-namespace:ClashDemo.ViewModels"
      mc:Ignorable="d" 
      xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers;assembly=Clash.UI.Suppot"
      d:DataContext="{d:DesignInstance Type=vm:HomePageViewModel}"
      Name="首页"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomPage">
    <Page.Resources>

    </Page.Resources>

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Canvas  Background="{DynamicResource commonBarBrush}">
            <Canvas.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="2" Opacity="0.6"/>
            </Canvas.Effect>
            <TextBlock Canvas.Top="18" Canvas.Left="20" FontSize="20" Text="首 页" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Style="{StaticResource circlButton}" 
                    Content="{StaticResource slimGeometry}"
                    helpers:ControlSuspensionHelper.IEnable="True"
                    Canvas.Right="100"  
                    Canvas.Top="16">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource ArrowToolTip}"
                             Content="轻量模式">
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Button Style="{StaticResource circlButton}" 
                    Content="{StaticResource circlHelperGeometry}"
                    Canvas.Right="60"
                    Canvas.Top="16"
                    Command="{Binding ShowOperatingInstructionsCommand}">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource ArrowToolTip}"
                             Content="说明">
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Button Style="{StaticResource circlButton}"
                    Content="{StaticResource commonSettingGeometry}" 
                    Canvas.Right="20" 
                    Canvas.Top="16" 
                    Command="{Binding ShowSettingDialogCommand}"
                    >
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource ArrowToolTip}"
                             Content="设置">
                    </ToolTip>
                </Button.ToolTip>
            </Button>
        </Canvas>


        <ScrollViewer Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}" VerticalScrollBarVisibility="Hidden">
            <UniformGrid Columns="2" Rows="2" VerticalAlignment="Top">
                <subview:SubscribBoard Margin="10 12 5 5" DataContext="{Binding SubscrubBoardViewModel}" />
                <subview:NetAgentBoard Margin="5 12 10 5" DataContext="{Binding NetAgentBoardViewModel}"/>
            </UniformGrid>
        </ScrollViewer>
        <!--<Grid Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}">
            <

        </Grid>-->
    </Grid>

</Page>
