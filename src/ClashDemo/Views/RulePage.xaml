<Page x:Class="ClashDemo.Views.RulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClashDemo.Views"
      xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
      xmlns:vm="clr-namespace:ClashDemo.ViewModels"
      xmlns:uiHelpers="clr-namespace:Clash.UI.Suppot.UI.Helpers;assembly=Clash.UI.Suppot"
      xmlns:validations="clr-namespace:Clash.UI.Suppot.UI.Validation;assembly=Clash.UI.Suppot"
      xmlns:componets="clr-namespace:Clash.UI.Suppot.UI.Componentes;assembly=Clash.UI.Suppot"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:charComponents="clr-namespace:ClashDemo.Views.ChartComponentes"
      mc:Ignorable="d" 
      Name="规则"
      d:DataContext="{d:DesignInstance Type=vm:RulePageViewModel}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RulePage">

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Canvas  Background="{DynamicResource commonBarBrush}">
            <Canvas.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="2" Opacity="0.6"/>
            </Canvas.Effect>
            <TextBlock Canvas.Top="18" Canvas.Left="20" FontSize="20" Text="规 则" FontWeight="Bold" VerticalAlignment="Center"/>
        </Canvas>


        <Grid Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <controls:TooltipTextBoxWithFilter Grid.Column="2" Margin="10 10 10 0" BottomTipText="过滤条件" />


            <StackPanel Grid.Row="1" Margin="10">
                <TextBox HorizontalAlignment="Center" d:Text="2026-07-16 10:30:00">
                    <TextBox.Resources>
                        <uiHelpers:BindingProxy x:Key="datacontextProxy" Data="{Binding DataContext,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=TextBox}}"/>

                        <Style TargetType="TextBox">
                            <Setter Property="FontSize" Value="18" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                                CornerRadius="4"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ScrollViewer HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="PART_ContentHost" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <ToolTip Style="{StaticResource ArrowToolTip}" Content="{Binding Data.TestValue, Source={StaticResource datacontextProxy}}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Validation.ErrorTemplate">
                                <Setter.Value>
                                    <ControlTemplate >
                                        <StackPanel Orientation="Horizontal">
                                            <AdornedElementPlaceholder Name="customAdorner"></AdornedElementPlaceholder>
                                            <TextBox Text="{Binding ElementName=customAdorner, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}" Margin="10,0,0,0" BorderBrush="Red" Foreground="Red" VerticalContentAlignment="Center" >
                                            </TextBox>
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Resources>
                    <TextBox.Text>
                        <Binding Path="TestValue" UpdateSourceTrigger="PropertyChanged" >
                            <Binding.ValidationRules>
                                <validations:DateTimeTextValidation >
                                </validations:DateTimeTextValidation>
                            </Binding.ValidationRules>
                        </Binding>

                    </TextBox.Text>

                </TextBox>

                <lvc:CartesianChart Series="{Binding SeriesCollection}" Height="350"  Background="White" Margin="10" LegendLocation="Top">
                    <lvc:CartesianChart.DataTooltip>
                        <charComponents:CustomTooltip  SelectionMode="SharedXValues"/>
                    </lvc:CartesianChart.DataTooltip>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="TOP" Labels="{Binding XAxis }" />
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="次数" LabelFormatter="{Binding FormatterCount}" />
                        <lvc:Axis Title="时长/分钟" LabelFormatter="{Binding FormatterDuring}" Position="RightTop" />
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
