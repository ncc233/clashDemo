<Page x:Class="ClashDemo.Views.SubscribePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClashDemo.Views"
      xmlns:components="clr-namespace:Clash.UI.Suppot.UI.Componentes;assembly=Clash.UI.Suppot"
      xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
      xmlns:vm="clr-namespace:ClashDemo.ViewModels"
      d:DataContext="{d:DesignInstance Type=vm:SubscribPageViewModel}"
      xmlns:converters="clr-namespace:ClashDemo.Converters"
      xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers;assembly=Clash.UI.Suppot"
      mc:Ignorable="d" 
      Name="订阅"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SubscribePage">
    <Page.Resources>
        <converters:StringEmptyToBoolConverter x:Key="str2Bool"/>
    </Page.Resources>

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Canvas  Background="{DynamicResource commonBarBrush}">
            <Canvas.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="2" Opacity="0.6"/>
            </Canvas.Effect>
            <TextBlock Canvas.Top="18" Canvas.Left="20" FontSize="20" Text="订 阅" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Style="{StaticResource circlButton}" 
                    Content="{StaticResource slimGeometry}"
                    helpers:ControlSuspensionHelper.IEnable="True"
                    Command="{Binding ShowInfoWindowCommand}"
                    Canvas.Right="100"  
                    Canvas.Top="16">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource ArrowToolTip}"
                             Content="轻量模式">
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Button Style="{StaticResource circlButton}" 
                    Content="{StaticResource circlHelperGeometry}"
                    Canvas.Right="60"
                    Canvas.Top="16"
                    Command="{Binding ShowOperatingInstructionsCommand}">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource ArrowToolTip}"
                             Content="说明">
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Button Style="{StaticResource circlButton}"
                    Content="{StaticResource fireGeometry}" 
                    Foreground="{StaticResource jumpButtonForegroundBrush}"
                    Canvas.Right="20" 
                    Canvas.Top="16" 
                   
                    >
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource ArrowToolTip}"
                             Content="fire">
                    </ToolTip>
                </Button.ToolTip>
            </Button>
        </Canvas>


        <Grid Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Viewbox Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Left" Height="100" Margin="10">
                <components:SubscribeBoardItem Height="150" Width="350" />
            </Viewbox>
            <controls:TooltipTextBox Margin="10 0 185 0" Name="link" Text="{Binding LinkUrl}" BottomTipText="订阅文件链接"/>
            <Button Style="{StaticResource commonButtonStyle}" HorizontalAlignment="Right" Content="新建" Margin="0 0 5 0" />
            <Button Style="{StaticResource commonButtonStyle}" HorizontalAlignment="Right" Content="导入" IsEnabled="{Binding ElementName=link,Path=Text,Converter={StaticResource str2Bool}}" Margin="0 0 95 0"/>
        </Grid>
    </Grid>
</Page>
