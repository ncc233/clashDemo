<UserControl x:Class="ClashDemo.Views.Dialogs.AddTestingDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClashDemo.Views.Dialogs"
             xmlns:model="clr-namespace:ClashDemo.Models"
             xmlns:vm="clr-namespace:ClashDemo.ViewModels.SubPageViewModels"
             d:DataContext="{d:DesignInstance Type=vm:AddTestingDialogViewModel}"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
             mc:Ignorable="d" 
             Height="350" Width="445">
    <Border Background="White" CornerRadius="4" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.3*"/>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="1.3*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding BoardName}" 
                       VerticalAlignment="Center"   
                       FontSize="25"
                       Margin="20"/>
            <controls:HeaderTextBox Grid.Row="1" x:Name="testName" Style="{StaticResource headerTextBoxStyle}" Margin="0 -120 0 0" Header="名称" Text="{Binding CurrentModel.BlockName}" />
            <controls:HeaderTextBox Grid.Row="1" x:Name="testIcon" Style="{StaticResource headerTextBoxStyle}"  Header="图标"/>
            <controls:HeaderTextBox Grid.Row="1" x:Name="testAddress" Style="{StaticResource headerTextBoxStyle}" Margin="0 120 0 0" Header="测试地址" Text="{Binding CurrentModel.BlockURL}"/>
            <Canvas Grid.Row="2">
                <Button Canvas.Right="110" 
                                               Style="{StaticResource settingOperateButtonStyle}" 
                                               Content="取消"
                                               Command="{Binding CancelDashBoardSettingCommand}"/>
                <Button Canvas.Right="20"
                                               Style="{StaticResource settingOperateButtonStyle}"
                                               Content="保存"
                                               Command="{Binding SaveDaskBoardSettingCommand}"/>
            </Canvas>
        </Grid>
    </Border>
</UserControl>
