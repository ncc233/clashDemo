<Page x:Class="ClashDemo.Views.ConnectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClashDemo.Views"
      mc:Ignorable="d" 
      Name="连接"
      xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
      xmlns:component="clr-namespace:Clash.UI.Suppot.UI.Componentes;assembly=Clash.UI.Suppot"
      xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers;assembly=Clash.UI.Suppot"
      xmlns:vm="clr-namespace:ClashDemo.ViewModels"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConnectionPage"
      d:DataContext="{d:DesignInstance Type=vm:ConnectionPageViewModel}"
      xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:theme="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2">

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Canvas  Background="{DynamicResource commonBarBrush}">
            <Canvas.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="2" Opacity="0.6"/>
            </Canvas.Effect>
            <TextBlock Canvas.Top="18" Canvas.Left="20" FontSize="20" Text="连 接" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock FontSize="14" Text="下载量: 97.1MB" Canvas.Top="24" Canvas.Left="300"/>
            <TextBlock FontSize="14" Text="上传量: 20.9MB" Canvas.Top="24" Canvas.Left="430"/>
            <Button Style="{StaticResource circlButton}"
                    Content="{StaticResource menuGeometry}"
                    helpers:AttachPropertyHelper.InnerMargin="8"
                    Canvas.Right="120" 
                    Canvas.Top="16">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource RectToolTip}" Content="Click"/>
                </Button.ToolTip>
            </Button>

            <Button Style="{StaticResource commonButtonStyle}"
                    Height="29"
                    Content="关闭全部"
                    FontSize="13"
                    Canvas.Right="20" 
                    Canvas.Top="16" 
                   />
        </Canvas>


        <Grid Grid.Row="1" Background="{DynamicResource contentBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="10" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <controls:ButtonGroup HorizontalAlignment="Left" 
                                  Layout="Stack"
                                  Style="{StaticResource buttonGroup}"  
                                  Height="30" 
                                   >
                    <RadioButton Content="活跃 0" IsChecked="True"/>
                    <RadioButton Content="已关闭 194"  />
                </controls:ButtonGroup>
                <controls:TooltipTextBoxWithFilter Grid.Column="2" Margin="10 0 0 0"  BottomTipText="过滤条件" />
            </Grid>

            <Grid Grid.Row="1">
                <Path Data="{StaticResource emptyBoxGeometry}" Stretch="Uniform" Height="70" Width="70" Fill="#68686d"/>
                <TextBlock Text="空空如也" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" 
                           Margin="0 120 0 0"
                           FontSize="25"
                           Foreground="#68686d"
                           FontFamily="DengXian"
                           FontWeight="Regular"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
