<Application
    x:Class="ClashDemo.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ClashDemo.Converters"
    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    xmlns:local="clr-namespace:ClashDemo">
    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Clash.UI.Suppot;component/UISuppotAggregation.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="iconfont">pack://application:,,,/ClashDemo;component/Fonts/#iconfont</FontFamily>
            <converters:PageNaviagtionConverter x:Key="navigateConvert" />
            <!-- 托盘图标定义 -->
            <tb:TaskbarIcon
                x:Key="TrayIcon"
                IconSource="/Icons/tray-icon.ico"
                ToolTipText="ClashDemo"
                TrayMouseDoubleClick="TrayIcon_DoubleClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="显示主窗口" Click="ShowWindow_Click" />
                        <MenuItem Header="设置" Click="Settings_Click" />
                        <Separator />
                        <MenuItem Header="关于" Click="About_Click" />
                        <Separator />
                        <MenuItem Header="退出" Click="Exit_Click" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>

            <Style TargetType="{x:Type controls:CustomRadioButton}">
                <Setter Property="Height" Value="40" />
                <Setter Property="Width" Value="140" />
                <Setter Property="Background" Value="{DynamicResource customRadioButtonCommonBackground}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type controls:CustomRadioButton}">
                            <ControlTemplate.Resources>
                                <Storyboard x:Key="radioButtonCheckAnimation">
                                    <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)" To="{DynamicResource customRadioButtonCheckBackgroundColor}" Duration="0:0:0.2" />
                                    <ColorAnimation Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)" To="#ffffff" Duration="0:0:0.2" />
                                </Storyboard>
                                <Storyboard x:Key="radioButtonUncheckAnimation">
                                    <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)" To="{DynamicResource customRadioButtonCommonBackgroundColor}" Duration="00:00:0.2" />
                                    <ColorAnimation Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)" To="#000000" Duration="00:00:0.2" />
                                </Storyboard>
                            </ControlTemplate.Resources>
                            <Border
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="8">
                                <Grid>
                                    <Canvas>
                                        <Ellipse
                                            Name="statusDot"
                                            Canvas.Top="10"
                                            Canvas.Right="10"
                                            Width="{Binding RelativeSource={RelativeSource Mode=Self}, Path=ActualHeight}"
                                            Height="8"
                                            Visibility="Collapsed"
                                            Fill="White" />
                                    </Canvas>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                                        <Path
                                            Margin="4"
                                            Data="{TemplateBinding HeaderIcon}"
                                            Fill="{TemplateBinding Foreground}"
                                            Stretch="Uniform" />
                                        <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Content="{TemplateBinding Content}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
