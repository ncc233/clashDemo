<Application x:Class="ClashDemo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ClashDemo.Converters"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls;assembly=Clash.UI.Suppot"
             xmlns:local="clr-namespace:ClashDemo">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Clash.UI.Suppot;component/UISuppotAggregation.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:PageNaviagtionConverter x:Key="navigateConvert"/>

            <Style TargetType="{x:Type controls:CustomRadioButton}">
                <Setter Property="Height"  Value="40"/>
                <Setter Property="Width" Value="140" />
                <Setter Property="Background" Value="{DynamicResource customRadioButtonCommonBackground}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type controls:CustomRadioButton}">
                            <ControlTemplate.Resources>
                                <Storyboard x:Key="radioButtonCheckAnimation">
                                    <ColorAnimation Duration="0:0:0.2"
                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                To="{DynamicResource customRadioButtonCheckBackgroundColor}"/>
                                    <ColorAnimation Duration="0:0:0.2"
                                Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)"
                                To="#ffffff"/>
                                </Storyboard>
                                <Storyboard x:Key="radioButtonUncheckAnimation">
                                    <ColorAnimation Duration="00:00:0.2"
                                Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                To="{DynamicResource customRadioButtonCommonBackgroundColor}"/>
                                    <ColorAnimation Duration="00:00:0.2"
                                Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)"
                                To="#000000"/>
                                </Storyboard>
                            </ControlTemplate.Resources>
                            <Border Background="{TemplateBinding Background}" 
                                    BorderThickness="0"
                                    CornerRadius="8"
                                    Height="{TemplateBinding Height}"
                                    Width="{TemplateBinding Width}">
                                <Grid>
                                    <Canvas>
                                        <Ellipse 
                                            Name="statusDot"
                                            Visibility="Collapsed"
                                            Height="8" 
                                            Width="{Binding RelativeSource={RelativeSource Mode=Self},Path=ActualHeight}"
                                            Canvas.Top="10"
                                            Canvas.Right="10"
                                            Fill="White"/>
                                    </Canvas>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Path Data="{TemplateBinding HeaderIcon}" 
                                              Fill="{TemplateBinding Foreground}"
                                              Stretch="Uniform"
                                              Margin="4"/>
                                        <ContentPresenter 
                                            Content="{TemplateBinding Content}" 
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
