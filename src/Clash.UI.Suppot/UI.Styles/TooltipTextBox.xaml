<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
                    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Clash.UI.Suppot;component/UI.CommonResources/CommonGeometry.xaml"/>
        <ResourceDictionary Source="/Clash.UI.Suppot;component/UI.Styles/CirclButton.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <Style  TargetType="{x:Type controls:TooltipTextBox}">
        <Setter Property="Height" Value="35"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="helpers:AttachPropertyHelper.CornerRadius" Value="4"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="#ffffff"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:TooltipTextBox}">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="{TemplateBinding helpers:AttachPropertyHelper.CornerRadius}"/>
                        <Border Name="border" Background="Transparent" Margin="0 1 0 0" CornerRadius="{TemplateBinding helpers:AttachPropertyHelper.CornerRadius}" BorderThickness="1" BorderBrush="#c4c4c4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{TemplateBinding BottomTipText}" 
                                       Foreground="#c4c4c4" 
                                       TextAlignment="{TemplateBinding TextAlignment}"
                                       Margin="12.3 0 0 0"
                                       VerticalAlignment="{TemplateBinding VerticalAlignment}"/>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="10 0 0 0"
                                          Focusable="false"
                                          VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          />
                            <Button x:Name="PART_clipButton" Grid.Column="1"
                                    Content="{StaticResource clipboardGeometry}" 
                                    Style="{StaticResource circlButton}"
                                    Foreground="#c4c4c4"
                                    Width="28"
                                    HorizontalAlignment="Left"/>
                            <Button x:Name="PART_clearButton"
                                    Visibility="Collapsed" 
                                    Grid.Column="1" Content="{StaticResource clearOrCloseGeometry}" 
                                    Foreground="#c4c4c4"  
                                    Style="{StaticResource circlButton}" 
                                    Width="28"  HorizontalAlignment="Left"
                                    helpers:AttachPropertyHelper.InnerMargin="8"/>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#000000"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#007aff"/>
                            <Setter TargetName="border" Property="Margin" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>