<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Clash.UI.Suppot.UI.Controls"
                    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
                    xmlns:component="clr-namespace:Clash.UI.Suppot.UI.Componentes"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ========== 笔刷部分 ========== -->
    <SolidColorBrush x:Key="ItemNormalBackground" Color="White" />
    <SolidColorBrush x:Key="ItemMouseOverBackground" Color="#e3e3e3" />
    <SolidColorBrush x:Key="ItemSelectedBackground" Color="#cfdeee" />
    <SolidColorBrush x:Key="ButtonNormalForeground" Color="#129946" />
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#c1d3e7" />
    <SolidColorBrush x:Key="CheckForeground" Color="#007aff" />
    <SolidColorBrush x:Key="ResetForeground" Color="#06943d" />
    <SolidColorBrush x:Key="BadgeBorderBrush" Color="#cccccc" />
    <SolidColorBrush x:Key="BadgeForegroundBrush" Color="#cccccc" />



    <Storyboard x:Key="listBoxItemSelected">
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetName="bottomBorder"
            Storyboard.TargetProperty="Opacity"
            >
            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
            <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="0"/>
            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimation Storyboard.TargetName="topBorder"
                         Storyboard.TargetProperty="Opacity"
                         Duration="0:0:0.4"
                         To="0.2"/>
    </Storyboard>
    <Storyboard x:Key="listBoxItemUnselected">
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetName="bottomBorder"
            Storyboard.TargetProperty="Opacity"
            >
            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
            <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="0"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimation Storyboard.TargetName="topBorder"
                         Storyboard.TargetProperty="Opacity"
                         Duration="0:0:0.4"
                         To="0"/>
    </Storyboard>

    <Style x:Key="agentNetItem" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Height" Value="55"/>
        <Setter Property="helpers:AttachPropertyHelper.CornerRadius" Value="5"/>
        <Setter Property="helpers:RippleAnimationHelper.IsEnable" Value="True"/>
        <Setter Property="helpers:RippleAnimationHelper.RippleTime" Value="0.4"/>
        <Setter Property="helpers:RippleAnimationHelper.RippleParentRadius" Value="5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <Border Name="bottomBorder"
                                Margin="-2.7 0 2 0" 
                                Background="{StaticResource CheckForeground}" 
                                CornerRadius="7"
                                Opacity="0"/>
                        <Border Name="middleBorder" CornerRadius="{TemplateBinding helpers:AttachPropertyHelper.CornerRadius}" Background="{StaticResource ItemNormalBackground}"/>
                        <Border Name="topBorder" CornerRadius="{TemplateBinding helpers:AttachPropertyHelper.CornerRadius}" Background="{StaticResource CheckForeground}" Opacity="0"/>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="middleBorder" Property="Background" Value="{StaticResource ItemMouseOverBackground}"/>
                        </MultiTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource listBoxItemSelected}"/>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource listBoxItemUnselected}"/>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== ListBox 样式 (key: agentNetListBoxStyle) ========== -->
    <Style x:Key="agentNetListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid VerticalAlignment="Center" Columns="2" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle" Value="{StaticResource agentNetItem}" />
    </Style>

</ResourceDictionary>