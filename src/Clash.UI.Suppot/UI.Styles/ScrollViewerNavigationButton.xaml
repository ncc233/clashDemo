<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls">

    <Storyboard x:Key="mouseOverAnimation">
        <DoubleAnimation
            Storyboard.TargetName="border"
            Storyboard.TargetProperty="Opacity"
            To="1"
            Duration="0:0:0.2" />
        <ColorAnimation Storyboard.TargetProperty="Foreground.Color" To="#ffffff" Duration="0:0:0.2" />
    </Storyboard>
    <Storyboard x:Key="notMouseOverAnimation">
        <DoubleAnimation
            Storyboard.TargetName="border"
            Storyboard.TargetProperty="Opacity"
            To="0"
            Duration="0:0:0.2" />
        <ColorAnimation Storyboard.TargetProperty="Foreground.Color" To="#868689" Duration="0:0:0.2" />
    </Storyboard>
    <Style TargetType="{x:Type controls:ScrollButton}">
        <Setter Property="Height" Value="27" />
        <Setter Property="Foreground" Value="#868689" />
        <Setter Property="Width" Value="27" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="200" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="10" />
        <Setter Property="helpers:RippleAnimationHelper.IsEnable" Value="True" />
        <Setter Property="helpers:RippleAnimationHelper.IsControlCenter" Value="True" />
        <Setter Property="helpers:RippleAnimationHelper.RippleBrush" Value="#ffffff" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ScrollButton}">
                    <Grid>
                        <Border Name="border" Opacity="0" Background="#3394ff" />
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource mouseOverAnimation}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource notMouseOverAnimation}" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>