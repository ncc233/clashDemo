<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="ArrowToolTip" TargetType="ToolTip">
        <Setter Property="VerticalOffset" Value="40" />
        <Setter Property="Placement" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <StackPanel>
                        <Path HorizontalAlignment="Center" Data="M 6 0 L 0 6 L 12 6 Z" Fill="#E6333333" />
                        <Border
                            MinWidth="50"
                            MinHeight="20"
                            CornerRadius="2"
                            Background="#E6333333">
                            <TextBlock
                                Margin="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{TemplateBinding Content}"
                                Foreground="White" />
                        </Border>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ArrowToolTipLeft" TargetType="ToolTip">
        <Setter Property="HorizontalOffset" Value="4" />
        <Setter Property="PlacementRectangle" Value="-10 0 5 5" />
        <Setter Property="Placement" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border
                            MinWidth="50"
                            MinHeight="20"
                            CornerRadius="2"
                            Background="#E6333333">
                            <TextBlock
                                Margin="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{TemplateBinding Content}"
                                Foreground="White" />
                        </Border>
                        <Path
                            Margin="-3,0,0,0"
                            Data="M 6 0 L 0 6 L 12 6 Z"
                            Fill="#E6333333"
                            Stretch="Uniform"
                            RenderTransformOrigin="0.5 0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="90" />
                            </Path.RenderTransform>
                        </Path>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RectToolTip" TargetType="ToolTip">
        <Setter Property="VerticalOffset" Value="40" />
        <Setter Property="Placement" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <StackPanel>
                        <Border
                            MinWidth="50"
                            MinHeight="20"
                            CornerRadius="2"
                            Background="#E6333333">
                            <TextBlock
                                Margin="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{TemplateBinding Content}"
                                Foreground="White" />
                        </Border>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>