<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Clash.UI.Suppot;component/UI.CommonResources/CommonBrush.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <Storyboard x:Key="customRadioButtonCheckAnimation">
        <ColorAnimation Storyboard.TargetProperty="Background.Color" To="{StaticResource customRadioButtonCheckBackgroundColor}" Duration="0:0:0.2" />
        <ColorAnimation Storyboard.TargetProperty="Foreground.Color" To="#ffffff" Duration="0:0:0.2" />
    </Storyboard>
    <Storyboard x:Key="customRadioButtonUncheckAnimation">
        <ColorAnimation Storyboard.TargetProperty="Background.Color" To="{StaticResource customRadioButtonCommonBackgroundColor}" Duration="0:0:0.2" />
        <ColorAnimation Storyboard.TargetProperty="Foreground.Color" To="#000000" Duration="0:0:0.2" />
    </Storyboard>
    <Style x:Key="customRadioButtonStyle" TargetType="{x:Type controls:CustomRadioButton}">
        <Setter Property="Height" Value="41.5" />
        <Setter Property="helpers:ControlSuspensionHelper.IEnable" Value="True" />
        <Setter Property="helpers:ControlSuspensionHelper.MoveValue" Value="1" />
        <Setter Property="Foreground" Value="#000000" />
        <Setter Property="MaxWidth" Value="300" />
        <Setter Property="MinWidth" Value="160" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="{DynamicResource customRadioButtonCommonBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CustomRadioButton}">
                    <Grid Margin="{TemplateBinding Margin}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                                    <Path
                                        MaxWidth="16.5"
                                        MaxHeight="16.5"
                                        Margin="0,0,3,0"
                                        VerticalAlignment="Center"
                                        Data="{TemplateBinding HeaderIcon}"
                                        Stretch="Uniform"
                                        Fill="{TemplateBinding Foreground}" />
                                    <TextBlock
                                        Margin="4"
                                        VerticalAlignment="Center"
                                        Text="{TemplateBinding Content}"
                                        TextAlignment="Center"
                                        Foreground="{TemplateBinding Foreground}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border
                            Name="lineBorder"
                            Width="2"
                            Height="20"
                            Margin="0,32,0,-20"
                            VerticalAlignment="Center"
                            Visibility="Hidden"
                            Background="{StaticResource jumpButtonForegroundBrush}" />
                        <Canvas Background="Transparent">
                            <Ellipse
                                Name="statuPoint"
                                Canvas.Top="8"
                                Canvas.Right="8"
                                Width="7"
                                Height="7"
                                Fill="#ffffff"
                                Stretch="Uniform"
                                Visibility="Hidden" />
                        </Canvas>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsRun" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="statuPoint" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="IsRun" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="statuPoint" Property="Visibility" Value="Visible" />
                            <Setter TargetName="statuPoint" Property="Fill" Value="Green" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="IsRun" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="statuPoint" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="statuPoint" Property="Fill" Value="#ffffff" />
                        </MultiTrigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter TargetName="lineBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <EventTrigger RoutedEvent="Checked">
                            <EventTrigger.Actions>
                                <BeginStoryboard Storyboard="{StaticResource customRadioButtonCheckAnimation}" />
                            </EventTrigger.Actions>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Unchecked">
                            <EventTrigger.Actions>
                                <BeginStoryboard Storyboard="{StaticResource customRadioButtonUncheckAnimation}" />
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <Style x:Key="customRadioButtonMin" TargetType="{x:Type controls:CustomRadioButton}" BasedOn="{StaticResource customRadioButtonStyle}">
        <Setter Property="MaxWidth" Value="130" />
        <Setter Property="MinWidth" Value="96.6" />
        <Setter Property="IsRun" Value="False" />
    </Style>

</ResourceDictionary>