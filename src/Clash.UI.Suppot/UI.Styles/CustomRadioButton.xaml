<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
                    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Clash.UI.Suppot;component/UI.CommonResources/CommonBrush.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <Storyboard x:Key="customRadioButtonCheckAnimation">
        <ColorAnimation Duration="0:0:0.2"
                        Storyboard.TargetProperty="Background.Color"
                        To="{StaticResource customRadioButtonCheckBackgroundColor}"/>
        <ColorAnimation Duration="0:0:0.2"
                        Storyboard.TargetProperty="Foreground.Color"
                        To="#ffffff"/>
    </Storyboard>
    <Storyboard x:Key="customRadioButtonUncheckAnimation">
        <ColorAnimation Duration="0:0:0.2"
                        Storyboard.TargetProperty="Background.Color"
                        To="{StaticResource customRadioButtonCommonBackgroundColor}"/>
        <ColorAnimation Duration="0:0:0.2"
                        Storyboard.TargetProperty="Foreground.Color"
                        To="#000000"/>
    </Storyboard>
    <Style x:Key="customRadioButtonStyle" TargetType="{x:Type controls:CustomRadioButton}">
        <Setter Property="Height"  Value="41.5"/>
        <Setter Property="helpers:ControlSuspensionHelper.IEnable" Value="True"/>
        <Setter Property="helpers:ControlSuspensionHelper.MoveValue" Value="1"/>
        <Setter Property="Foreground" Value="#000000"/>
        <Setter Property="MaxWidth" Value="300"/>
        <Setter Property="MinWidth" Value="160"/>
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="{DynamicResource customRadioButtonCommonBackground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CustomRadioButton}">
                    <Grid Margin="{TemplateBinding Margin}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <Grid >
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                    <Path Data="{TemplateBinding HeaderIcon}" Stretch="Uniform"
                                      MaxHeight="16.5" MaxWidth="16.5"
                                      VerticalAlignment="Center"
                                          Margin="0 0 3 0"
                                      Fill="{TemplateBinding Foreground}"/>
                                    <TextBlock  Text="{TemplateBinding Content}"
                                           Margin="4"
                                            VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Name="lineBorder" Visibility="Hidden" Background="{StaticResource jumpButtonForegroundBrush}" Width="2" Height="20" VerticalAlignment="Center" Margin="0 32 0 -20"/>
                        <Canvas Background="Transparent">
                            <Ellipse Name="statuPoint" 
                                Fill="#ffffff" Stretch="Uniform" Height="7" Width="7"
                                     Visibility="Hidden"
                                     Canvas.Top="8"
                                     Canvas.Right="8"/>
                        </Canvas>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="IsRun" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="statuPoint" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsRun" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="statuPoint" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="statuPoint" Property="Fill" Value="Green"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False"/>
                                <Condition Property="IsRun" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="statuPoint" Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="statuPoint" Property="Fill" Value="#ffffff"/>
                        </MultiTrigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter TargetName="lineBorder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="Checked">
                            <EventTrigger.Actions>
                                <BeginStoryboard Storyboard="{StaticResource customRadioButtonCheckAnimation}"/>
                            </EventTrigger.Actions>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Unchecked">
                            <EventTrigger.Actions>
                                <BeginStoryboard Storyboard="{StaticResource customRadioButtonUncheckAnimation}"/>
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <Style x:Key="customRadioButtonMin" TargetType="{x:Type controls:CustomRadioButton}" BasedOn="{StaticResource customRadioButtonStyle}">
        <Setter Property="MaxWidth" Value="130" />
        <Setter Property="MinWidth" Value="96.6" />
        <Setter Property="IsRun"    Value="False"/>
    </Style>

</ResourceDictionary>