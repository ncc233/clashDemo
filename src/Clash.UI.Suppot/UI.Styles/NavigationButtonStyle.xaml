<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:local="clr-namespace:Clash.UI.Suppot.UI.Controls"
                    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Style x:Key="navigationButtonBorder" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="navigationPathGeometry" TargetType="Path">
        <Setter Property="Data" Value="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=HeaderIcon}" />
        <Setter Property="Stretch"  Value="Uniform"/>
        <Setter Property="Fill" Value="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=Foreground}" />
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment"  Value="Left"/>
        <Setter Property="Margin" Value="10" />
    </Style>
    <Style x:Key="navigationButtonContent" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=Foreground}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Text" Value="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=Content}" />
        <Setter Property="Grid.Column" Value="1" />
        <Setter Property="Margin" Value="40 0 5 0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style TargetType="{x:Type local:NavigationButton}">
        <Setter Property="Height" Value="50" />
        <Setter Property="Margin" Value="5 4 5 4" />
        <Setter Property="helpers:RippleAnimationHelper.IsEnable" Value="True"/>
        <Setter Property="helpers:RippleAnimationHelper.RippleParentRadius" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:NavigationButton}">
                    <Border Name="groundBorder" Style="{StaticResource navigationButtonBorder}">
                        <Grid x:Name="superButtonTgrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>  
                                <ColumnDefinition Width="7*"/>  
                            </Grid.ColumnDefinitions>
                            <Path  Style="{StaticResource navigationPathGeometry}"/>
                            <TextBlock Style="{StaticResource navigationButtonContent}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="groundBorder" Property="Background" Value="{DynamicResource navigationItemIsMouseOverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="groundBorder" Property="Background" Value="{DynamicResource navigationItemSelectedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>