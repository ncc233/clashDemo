<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:Clash.UI.Suppot.UI.Converters"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">


    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Clash.UI.Suppot;component/UI.CommonResources/CommonBrush.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <Style x:Key="ToggleSwitchCheckBoxStyle" TargetType="{x:Type CheckBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Grid Width="39" Height="24">
                        <!-- 轨道 -->
                        <Border x:Name="TrackBorder"
                             
                            CornerRadius="12"
                            Background="{DynamicResource thumbButtonCommonBackgroundBrush}"/>
                        <!-- 滑块 -->
                        <Ellipse x:Name="ThumbEllipse"
                             Width="21" Height="21"
                             Fill="White"
                             Margin="1 0 0 0"
                             HorizontalAlignment="Left">
                        </Ellipse>
                        <ContentPresenter Margin="50,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 轨道背景色变为绿色 -->
                                        <ColorAnimation Storyboard.TargetName="TrackBorder"
                                                    Storyboard.TargetProperty="Background.Color"
                                                    To="{StaticResource thumbButtonCheckBackground}" Duration="0:0:0.2"/>
                                        <!-- 滑块移动到右侧（偏移20） -->
                                        <ThicknessAnimation Storyboard.TargetName="ThumbEllipse"
                                                     Storyboard.TargetProperty="Margin"
                                                     To="17 0 0 0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 轨道背景色恢复灰色 -->
                                        <ColorAnimation Storyboard.TargetName="TrackBorder"
                                                    Storyboard.TargetProperty="Background.Color"
                                                    To="{StaticResource thumbButtonCommonBackground}" Duration="0:0:0.2"/>
                                        <!-- 滑块回到左侧 -->
                                        <ThicknessAnimation Storyboard.TargetName="ThumbEllipse"
                                                     Storyboard.TargetProperty="Margin"
                                                     To="1 0 0 0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>