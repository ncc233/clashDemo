<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls"
    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers">
    <!--<ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Clash.UI.Suppot;component/UI.CommonResources/CommonBrush.xaml"/>
    </ResourceDictionary.MergedDictionaries>-->
    <Storyboard x:Key="isjumpButtonMouseOver">
        <ColorAnimation Storyboard.TargetProperty="Background.Color" To="#007aff" Duration="0:0:0.2" />
        <ColorAnimation
            Storyboard.TargetName="backBorder"
            Storyboard.TargetProperty="Background.Color"
            To="#f5faff"
            Duration="0:0:0.2" />

    </Storyboard>
    <Storyboard x:Key="isNotjumpButtonMouseOver">
        <ColorAnimation Storyboard.TargetProperty="Background.Color" To="#7fbcff" Duration="0:0:0.2" />
        <ColorAnimation
            Storyboard.TargetName="backBorder"
            Storyboard.TargetProperty="Background.Color"
            To="Transparent"
            Duration="0:0:0.2" />

    </Storyboard>

    <Style x:Key="jumpButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource jumpButtonborderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource jumpButtonForegroundBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="helpers:RippleAnimationHelper.IsEnable" Value="True" />
        <Setter Property="helpers:RippleAnimationHelper.RippleParentRadius" Value="5" />
        <Setter Property="helpers:RippleAnimationHelper.RippleBrush" Value="{DynamicResource jumpButtonForegroundBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Height" Value="33" />
        <Setter Property="Width" Value="80" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="backBorder"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        BorderBrush="{TemplateBinding Background}"
                        CornerRadius="5"
                        BorderThickness="0.5"
                        Background="Transparent">
                        <Grid x:Name="superButtonTgrid">
                            <TextBlock
                                Margin="9,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="{TemplateBinding Content}"
                                FontSize="13" />
                            <Path
                                Margin="10,9,10,9"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Data="{TemplateBinding Tag}"
                                Stretch="Uniform"
                                Fill="{TemplateBinding Foreground}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource isjumpButtonMouseOver}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource isNotjumpButtonMouseOver}" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>