<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Clash.UI.Suppot;component/UI.Styles/DelayTestButtonStyle.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <Style TargetType="{x:Type controls:AgentContentControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AgentContentControl}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10 0 0 0">
                            <TextBlock Text="{TemplateBinding Header}"   Margin="0 2 0 1" FontSize="14"/>
                            <StackPanel Orientation="Horizontal"   >
                                <TextBlock Foreground="#8a8a8e" Margin="0 2 0 0" Text="{TemplateBinding SubHeader}" FontSize="14"/>
                                <ItemsControl Margin="2 0 0 0" ItemsSource="{TemplateBinding AgentSource}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent" 
                                    BorderBrush="#8a8a8e" 
                                    BorderThickness="1" 
                                    CornerRadius="2"
                                    Margin="2">
                                                <TextBlock FontSize="10" Foreground="#8a8a8e" Text="{Binding}" Margin="2"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                        <Control VerticalAlignment="Center"  Grid.Column="1" Margin="0 3.5 0 0"  Style="{StaticResource delayCirclGroup}" IsEnabled="{TemplateBinding IsTesting}" Background="#8e949f"  Height="18" Width="40"   />
                        <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0 8 10 8">
                            <Border x:Name="delayBorder" Background="#007aff" 
                        CornerRadius="3" 
                        Margin="-2 0"
                        Opacity="0.4"
                        Visibility="Hidden"/>
                            <Button x:Name="delayButton" Background="Transparent" 
                                    FontSize="15" 
                                    BorderThickness="0" 
                                    Content="{TemplateBinding Delay}" 
                                    Command="{TemplateBinding SingleDelayTest}" 
                                    Visibility="Visible"
                                    Foreground="#007aff">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template" >
                                            <Setter.Value>
                                                <ControlTemplate  TargetType="Button">
                                                    <Grid>
                                                        <ContentPresenter  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition  Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsTesting" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="delayBorder" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                        <Trigger Property="IsTesting" Value="True">
                            <Setter TargetName="delayButton" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
                
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>