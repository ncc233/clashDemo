<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
                    xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls"
                    xmlns:convert="clr-namespace:Clash.UI.Suppot.UI.Converters"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="circlButton" TargetType="Button">
        <Setter Property="Width" Value="33" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Mode=Self},Path=Width}"/>
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="200"/>
        <Setter Property="ToolTipService.BetweenShowDelay" Value="10"/>
        <Setter Property="helpers:RippleAnimationHelper.IsEnable" Value="True"/>
        <Setter Property="helpers:RippleAnimationHelper.IsControlCenter" Value="True"/>
        <Setter Property="helpers:RippleAnimationHelper.RippleParentRadius" Value="20"/>
        <Setter Property="helpers:AttachPropertyHelper.InnerMargin" Value="5"/>
        <Setter Property="Foreground" Value="{DynamicResource commonForegroundDarkBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse Name="mousoverBackground" Fill="#000000" Opacity="0"/>
                        <Path  Margin="{TemplateBinding helpers:AttachPropertyHelper.InnerMargin}" Data="{TemplateBinding Content}"  Fill="{TemplateBinding Foreground}" Stretch="Uniform"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="mousoverBackground" Property="Opacity" Value="0.05"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style   TargetType="{x:Type controls:OrderButton}" BasedOn="{StaticResource circlButton}">
    </Style>

</ResourceDictionary>