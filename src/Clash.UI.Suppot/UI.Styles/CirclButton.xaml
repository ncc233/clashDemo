<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Storyboard x:Key="circlAnimation" >
       <DoubleAnimation 
           Storyboard.TargetName="mouseOperationborder"
           Storyboard.TargetProperty="Width"
           From="0"
           Duration="0:0:0.25" To="33" />
       <DoubleAnimation 
           Storyboard.TargetName="mouseOperationborder"
           Storyboard.TargetProperty="Height"
           From="0"
           Duration="0:0:0.25" To="33" />
        <DoubleAnimation 
            Storyboard.TargetName="mouseOperationborder"
            Storyboard.TargetProperty="Opacity"
            From="0"
            Duration="0:0:0.25" To="0.4"/>
    </Storyboard>
    <Storyboard x:Key="circlAnimationReverce" >
        <DoubleAnimation
            Storyboard.TargetName="mouseOperationborder"
            Storyboard.TargetProperty="Opacity"
            BeginTime="0:0:0.3"
            Duration="0:0:0.2" To="0"/>
    </Storyboard>
    <Style x:Key="circlButton" TargetType="Button">
        <Setter Property="Width" Value="33" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Height" Value="{Binding RelativeSource={RelativeSource Mode=Self},Path=Width}"/>
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource commonForegroundDarkBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse Name="mousoverBackground" Fill="#000000" Opacity="0"/>
                        <Ellipse Name="mouseOperationborder" Fill="#000000" Opacity="0"/>
                        <Path Margin="7" Data="{TemplateBinding Content}" Fill="{TemplateBinding Foreground}" Stretch="Uniform"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="mousoverBackground" Property="Opacity" Value="0.05"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="Button.PreviewMouseDown">
                            <EventTrigger.Actions>
                                <BeginStoryboard Storyboard="{StaticResource circlAnimation}"/>
                            </EventTrigger.Actions>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.PreviewMouseUp">
                            <EventTrigger.Actions>
                                <BeginStoryboard Storyboard="{StaticResource circlAnimationReverce}"/>
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>