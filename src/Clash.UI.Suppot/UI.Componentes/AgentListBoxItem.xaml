<UserControl x:Class="Clash.UI.Suppot.UI.Componentes.AgentListBoxItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Clash.UI.Suppot.UI.Componentes"
             mc:Ignorable="d" 
             d:DesignHeight="55" d:DesignWidth="300">
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10 0 0 0">
            <TextBlock x:Name="header" Text="1200" Margin="0 2 0 1" FontSize="14" />
            <StackPanel Orientation="Horizontal"   >
                <TextBlock x:Name="subHeader" Foreground="#8a8a8e" Margin="0 2 0 0" Text="1200" FontSize="14"/>
                <ItemsControl x:Name="badgeSource" Margin="2 0 0 0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" 
                                    BorderBrush="#8a8a8e" 
                                    BorderThickness="1" 
                                    CornerRadius="2"
                                    Margin="2">
                                <TextBlock FontSize="10" Foreground="#8a8a8e" Text="{Binding}" Margin="2"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0 0 13 0">
            <Grid>
                <Border x:Name="delayBorder" Background="#007aff" 
                        CornerRadius="3" 
                        Margin="-2 0"
                        Opacity="0.4"
                        Visibility="Hidden"/>
                <Button x:Name="delayButton" Background="Transparent" FontSize="15" BorderThickness="0" Content="50" Visibility="Visible">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template" >
                                <Setter.Value>
                                    <ControlTemplate  TargetType="Button">
                                        <Grid>
                                            <ContentPresenter  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
        <Viewbox  Grid.Column="1" Height="10" Width="40"  HorizontalAlignment="Right"  Margin="0 0 11 0">
            <Control x:Name="delayAnimationControl" Style="{StaticResource delayCirclGroup}" IsEnabled="False" Background="#8e949f"  Height="18" Width="60" Grid.Row="3"  />
        </Viewbox>
    </Grid>
</UserControl>
