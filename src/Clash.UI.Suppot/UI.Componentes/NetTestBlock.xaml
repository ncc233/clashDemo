<UserControl x:Class="Clash.UI.Suppot.UI.Componentes.NetTestBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Clash.UI.Suppot.UI.Componentes"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls"
             mc:Ignorable="d" 
             Height="140" Width="75"
             d:DesignHeight="65" d:DesignWidth="40">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Border CornerRadius="4" Grid.RowSpan="4" Background="#007aff" Opacity="0.1">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard >
                                        <DoubleAnimation Duration="0:0:0.4"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard >
                                        <DoubleAnimation Duration="0:0:0.4"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
        <Path x:Name="icon" Height="20" Width="25" Margin="0 7 0 0"/>
        <TextBlock x:Name="testName" Grid.Row="1" VerticalAlignment="Center" FontSize="14" HorizontalAlignment="Center" Foreground="#8e949f"/>
        <Border Grid.Row="2" Height="1"  Background="#8e949f" Margin="8 0" />
        <controls:DelayTestButton  x:Name="buttonTest" Grid.Row="3" Content="1150" FontSize="6"  />
        <Control Style="{StaticResource delayCirclGroup}" Background="#8e949f" Margin="0 6 0 0" IsEnabled="{Binding ElementName=buttonTest,Path=IsTesting}" Grid.Row="3"  />
    </Grid>
</UserControl>
