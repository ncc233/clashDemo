<Window x:Class="Clash.UI.Suppot.UI.Componentes.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" Height="70" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="False"
        Loaded="Window_Loaded"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Window.Resources>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#80FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" CornerRadius="4" Background="{Binding BackgroundColor}">
        <!-- 在 Border 上定义变换组 -->
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="BorderScale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
                <TranslateTransform x:Name="BorderTranslate"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid Margin="10 4">
            <!-- 原有内容：图标、文本、关闭按钮 -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="IconText" Grid.Column="0" 
                       FontFamily="Segoe MDL2 Assets" FontSize="18"
                       VerticalAlignment="Center" Margin="0,0,10,0"
                       Foreground="White"/>

            <TextBlock x:Name="MessageText" Grid.Column="1"
                       TextWrapping="Wrap" VerticalAlignment="Center"
                       Foreground="White" FontSize="12"/>

            <Button Grid.Column="2" Content="×" Style="{StaticResource CloseButtonStyle}"
                    Width="25" Height="25" Click="CloseButton_Click"/>
        </Grid>
    </Border>
</Window>