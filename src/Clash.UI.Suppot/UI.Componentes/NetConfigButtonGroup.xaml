<UserControl x:Class="Clash.UI.Suppot.UI.Componentes.NetConfigButtonGroup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Clash.UI.Suppot.UI.Componentes"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="330">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <controls:CustomRadioButton  x:Name="systemRadioButton"
                Style="{StaticResource customRadioButtonStyle}"
                                         HeaderIcon="{StaticResource commonSettingGeometry}"
                                         Content="系统代理"
                                         IsRun="{Binding ElementName=systemAgentCheckBox,Path=IsChecked ,Mode=TwoWay}"
                                         Margin="3 3 2 3"/>
            <controls:CustomRadioButton x:Name="cardRadioButton"
                                        
                                        Style="{StaticResource customRadioButtonStyle}"
                                        IsRun="{Binding ElementName=cardAgentCheckBox,Path=IsChecked ,Mode=TwoWay}"
                                        HeaderIcon="{StaticResource commonCapacityGeometry}"
                                        Content="虚拟网卡模式"
                                        Margin="2 3 3 3"/>
        </StackPanel>
        <Border Grid.RowSpan="2"
                x:Name="contentBorder"
                Background="#f5f5f5"
                BorderBrush="#007aff" 
                Height="35" 
                Margin="16.4 28 16.4 0"
                CornerRadius="4"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="detailText" Foreground="#acacaf" FontSize="11"  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <Path x:Name="moreDetailPath" Height="10" Width="10" Margin="3 0 0 0" Stretch="Uniform" Fill="#acacaf" Data="{StaticResource checkGeometry}"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.RowSpan="2" 
                Margin="16.4 20 16.4 0"
                Background="#007aff"
                Opacity="0.1" 
                CornerRadius="5"
                Height="60"/>
        <Border Grid.Row="1" Grid.RowSpan="2" 
                x:Name="systemAgentBorder"
                Margin="22.4 20 22.4 0"
                Visibility="Hidden"
                Background="Green"
                Opacity="0.1" 
                CornerRadius="5"
                Height="44"/>
        <Border Grid.Row="1" Grid.RowSpan="2" 
                x:Name="cardAgentBorder"
                Margin="22.4 20 22.4 0"
                Visibility="Hidden"
                Background="Green"
                Opacity="0.1" 
                CornerRadius="5"
                Height="44"/>
        <StackPanel Grid.Row="1" Grid.RowSpan="2" 
                Margin="22.4 20 22.4 0"
                Height="44"
                    Orientation="Horizontal" VerticalAlignment="Center">
            <Path
                x:Name="statuPath"
                Height="22" 
                  Width="22"
                  Margin="11 0 0 0"
                  Data="{StaticResource delayOrder}"
                  Stretch="Uniform" 
                  Fill="#989b9e"/>

            <TextBlock x:Name="modeDescriptionText" FontSize="16" Text="系统代理" Margin="11 0 0 0" VerticalAlignment="Center"/>
            <Path Height="22" 
                  Width="22"
                  Margin="11 0 0 0"
                  Data="{StaticResource settingGeometry}"
                  Stretch="Uniform" 
                  Fill="#000000"/>
        </StackPanel>
        <CheckBox x:Name="systemAgentCheckBox" 
                  Grid.Row="1"
                  Grid.RowSpan="2" 
                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                  Margin="0 20 31 0"
                  HorizontalAlignment="Right"    
                  Height="44"/>
        <CheckBox x:Name="cardAgentCheckBox"
                  Grid.Row="1"
                  Grid.RowSpan="2" 
                  Visibility="Hidden"
                  Style="{StaticResource ToggleSwitchCheckBoxStyle}"
                  Margin="0 20 31 0"
                  HorizontalAlignment="Right"    
                  Height="44">
        </CheckBox>
    </Grid>
</UserControl>
