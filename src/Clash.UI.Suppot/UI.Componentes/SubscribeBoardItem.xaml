<UserControl x:Class="Clash.UI.Suppot.UI.Componentes.SubscribeBoardItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Clash.UI.Suppot.UI.Componentes"
             xmlns:helpers="clr-namespace:Clash.UI.Suppot.UI.Helpers"
             mc:Ignorable="d" 
             
             d:DesignHeight="150" d:DesignWidth="350">
    <Grid>
        <Border Margin="-4.5 0.5 0.5 0.5" Background="{StaticResource jumpButtonForegroundBrush}" CornerRadius="15"/>
        <Border Background="#ffffff" CornerRadius="15"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="12*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Grid.Column="1">
                <ContentControl Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Height="25" Cursor="SizeAll" >
                    <ContentControl.Content>
                        <Grid Background="Transparent">
                            <Path Data="{StaticResource subscribDragGeometry}" Stretch="Uniform" Fill="Black" HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <Path Data="{StaticResource subscribDragGeometry}" Stretch="Uniform" Fill="Black" HorizontalAlignment="Left" VerticalAlignment="Center"  Margin="10 0 0 0"/>
                        </Grid>
                    </ContentControl.Content>
                </ContentControl>
                <TextBlock Text="魔法喵" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource jumpButtonForegroundBrush}" 
                           Grid.Column="1" 
                           VerticalAlignment="Center" 
                           Margin="15 0 0 0"
                           FontSize="25"
                           TextAlignment="Center"/>
            </StackPanel>
            <Button Style="{StaticResource circlButton}"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Foreground="{StaticResource subscribBoardItemForegroundBrush}"
                    Click="Button_Click"
                           Margin="4 0"
                           Content="{StaticResource flashBoardGeometry}"
                           Command="{Binding FlashAllPointCommand}"
                           RenderTransformOrigin="0.5 0.5"
                           helpers:RotationBehaviorHelper.IsRotationEnabled="True"/>

            <Grid Grid.Column="1" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="WWW.abcmfmmmm..." 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Left"
                           Foreground="{StaticResource subscribBoardItemForegroundBrush}"
                           FontSize="20"/>
                <TextBlock Style="{StaticResource underlineTextBlockStyle}" 
                           Grid.Column="1" 
                           FontSize="20" 
                           Text="36 分钟" />
            </Grid>
            <Grid Grid.Row="2" Grid.Column="1">

                <TextBlock Text="26.3GB / 768GB" FontSize="18" Foreground="{StaticResource subscribBoardItemForegroundBrush}" HorizontalAlignment="Left"/>
                <TextBlock Text="2026-07-28" FontSize="18" Foreground="{StaticResource subscribBoardItemForegroundBrush}" HorizontalAlignment="Right"/>
                <ProgressBar Name="progressBar" 
                         Style="{DynamicResource subscribProcessStyle}" 
                         Value="18" 
                         Margin="0 4 0 0 "
                         Maximum="100" 
                         Minimum="0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
