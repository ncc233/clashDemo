<UserControl x:Class="Clash.UI.Suppot.UI.Componentes.AgentModeGroup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Clash.UI.Suppot.UI.Componentes"
             xmlns:controls="clr-namespace:Clash.UI.Suppot.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="330">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top">
            <controls:CustomRadioButton  x:Name="ruleRadio"
                Style="{StaticResource customRadioButtonMin}"
                                         HeaderIcon="{StaticResource ruleGeometry}"
                                         Content="规则"
                                         Margin="3 3 2 3"/>
            <controls:CustomRadioButton x:Name="globalRadio"
                                        Style="{StaticResource customRadioButtonMin}"
                                        HeaderIcon="{StaticResource connectionGeometry}"
                                        Content="全局"
                                        Margin="2 3 3 3"/>
            <controls:CustomRadioButton x:Name="directlyRadio"
                                        Style="{StaticResource customRadioButtonMin}"
                                        HeaderIcon="{StaticResource commonCapacityGeometry}"
                                        Content="直连"
                                        Margin="2 3 3 3"/>
        </StackPanel>
        <Border Grid.Row="1"
            Grid.RowSpan="2"
                VerticalAlignment="Top"
                x:Name="contentBorder"
                Background="#f5f5f5"
                BorderBrush="#007aff" 
                MaxHeight="70"
                MinHeight="35"
                Margin="16.4 57 16.4 0"
                CornerRadius="4"
                BorderThickness="1">
            <TextBlock x:Name="detailText"
                       Margin="8"
                       Foreground="#acacaf"
                       FontSize="12" 
                       LineHeight="18" 
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>

        </Border>
    </Grid>
</UserControl>

